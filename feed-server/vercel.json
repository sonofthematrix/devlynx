{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "public",
  "functions": {
    "api/server/[[...slug]].js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api/server" },
    {
      "source": "/:path((?!api/).+)",
      "destination": "/api/server/:path"
    }
  ]
}
