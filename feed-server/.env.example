# DevLynx AI feed server — variables used by server-with-ai.js
#
# Production (Vercel): set the same keys in Project → Settings → Environment Variables.
# Local: copy this file to .env and fill in secrets:
#   Windows:  copy .env.example .env
# Do not commit .env (see root .gitignore).
# Alleen `.env` wordt geladen door server-with-ai.js — niet `.env.local` (die kun je leeg laten).

# --- Required for AI ---
OPENAI_API_KEY=

# --- Default in code; production release uses this unless you override ---
OPENAI_MODEL=gpt-4o-mini

# --- Gumroad license verify + gated AI (set at least one; permalink wins if both are set) ---
# product_id from Gumroad product settings (must match the product that issued the license keys)
GUMROAD_PRODUCT_ID=
# OR slug from URL …/l/<slug> e.g. devlynx-ai for https://jcdreamz.gumroad.com/l/devlynx-ai
# GUMROAD_PRODUCT_PERMALINK=

# --- Optional: comma-separated keys accepted as valid licenses (server-only) ---
# DEV_CODES=

# --- Local dev only: extension defaults to port 2847 ---
# On Vercel, PORT is not used. For local Node, optional:
# PORT=2847

# --- Vercel Blob (screenshots on Vercel). From Vercel dashboard → Storage → Blob → .env ---
# BLOB_READ_WRITE_TOKEN=
# Optional fallback if your tooling only sets the legacy name:
# VERCEL_BLOB_READ_WRITE_TOKEN=

# --- RS256 private key (PEM) for signing free-trial JWTs: GET /trial-token, POST /trial-consume ---
# Must match the public key embedded in src/license-jwt-public.js — see developer/LICENSE-JWT-KEYS.md
# LICENSE_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Optional: initial trial uses for new device+extension IDs (default 20) ---
# DEVLYNX_TRIAL_LIMIT=20
