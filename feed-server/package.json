{
  "name": "feed-server",
  "version": "1.0.0",
  "description": "DevLynx AI feed server (Vercel or local Node)",
  "main": "server-with-ai.js",
  "scripts": {
    "start": "node server-with-ai.js",
    "gen:license-jwt-keys": "node ../scripts/gen-license-jwt-keys.js",
    "build": "node -e \"console.log('feed-server: API only (no static output)')\"",
    "build:prod": "npm run build:prod --prefix ..",
    "release": "npm run release --prefix .."
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@vercel/blob": "^0.27.3",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.3",
    "openai": "^4.20.0"
  }
}
