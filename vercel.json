{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node -e \"console.log('API deploy: skip extension build'); process.exit(0);\"",
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/[[...slug]].js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/", "destination": "/api" },
    {
      "source": "/:path((?!api/).+)",
      "destination": "/api/:path"
    }
  ]
}
